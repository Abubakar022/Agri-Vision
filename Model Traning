import os
import sys
import subprocess

print("🔄 Wiping conflicting libraries...")
# 1. Remove everything that causes conflicts
subprocess.check_call([sys.executable, "-m", "pip", "uninstall", "-y", 
                       "numpy", "pandas", "scipy", "docling", "bitsandbytes", "accelerate"])

print("⬇️ Installing Fresh Compatible Stack...")
# 2. Install in a specific order to lock versions
# A. Lock Numpy < 2.0 (Required for Docling)
# B. Install bitsandbytes & accelerate (Required for Qwen)
# C. Install Docling & LangChain
subprocess.check_call([sys.executable, "-m", "pip", "install", 
                       "numpy<2.0", 
                       "pandas<2.2.0",
                       "scipy<1.13.0",
                       "bitsandbytes>=0.43.0", 
                       "accelerate>=0.26.0",
                       "docling", 
                       "docling-core",
                       "langchain",
                       "langchain-community", 
                       "langchain-huggingface", 
                       "faiss-cpu", 
                       "sentence-transformers",
                       "--no-cache-dir"]) # Force fresh download

print("✅ Installation Complete.")
